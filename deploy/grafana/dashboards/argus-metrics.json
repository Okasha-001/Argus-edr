{
  "uid": "argus-metrics",
  "title": "ARGUS — Metrics",
  "tags": ["argus", "edr", "metrics"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Events / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(argus_events_total[$__rate_interval]))", "legendFormat": "events" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Alerts & incidents / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(argus_alerts_total[$__rate_interval]))", "legendFormat": "alerts" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(argus_incidents_total[$__rate_interval]))", "legendFormat": "incidents" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Pipeline stage latency (p95)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(argus_pipeline_stage_seconds_bucket[$__rate_interval])))", "legendFormat": "{{stage}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "eBPF program cost (ns / sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ns" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(argus_program_runtime_ns_total[$__rate_interval])", "legendFormat": "{{program}}" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Ring-buffer drops",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(argus_ring_drops_total)", "legendFormat": "drops" }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Enrolled agents",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(argus_server_agents)", "legendFormat": "agents" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Control plane — alerts & signals / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(argus_server_alerts_total[$__rate_interval]))", "legendFormat": "alerts" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(argus_server_signals_total[$__rate_interval]))", "legendFormat": "signals" }
      ]
    }
  ]
}
